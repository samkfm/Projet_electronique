#include <Wire.h>
#include <VL53L0X.h>

VL53L0X sensor;

void setup() {
  Serial.begin(9600);
  Wire.begin();

  sensor.init();
  sensor.setTimeout(500);

  Serial.println("Capteur pret");
}

void loop() {
  int distance = sensor.readRangeSingleMillimeters();

  if (sensor.timeoutOccurred()) {
    Serial.println("Timeout");
  } else {
    Serial.print("Distance: ");
    Serial.print(distance / 10.0);
    Serial.println(" cm");
  }

  delay(200);
}

